# Supabase do octo-dash2 (leitura anônima via views portal_*). anon key é pública por design.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...  # anon key (JWT legacy 'eyJ')
# Tenant fixo Lotus ("Japi Lançamentos")
NEXT_PUBLIC_TENANT_ID=65c69875-dc83-4062-90f6-6f6adc30df26

# Segredo do /api/revalidate (o trigger/edge function do Supabase envia no header x-revalidate-secret)
REVALIDATE_SECRET=troque-por-um-segredo-forte

# Dominio do portal (para og:image/canonical). Define no deploy o dominio final.
NEXT_PUBLIC_SITE_URL=https://www.lotusbrokers.com.br
